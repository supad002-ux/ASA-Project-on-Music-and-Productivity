# ============================================================
# 4. CONDITIONS FOR INFERENCE  (Unit 5)
# ============================================================
print("── SECTION 3: CONDITIONS FOR INFERENCE ───────────\n")

pop_needed = 10 * 66
print("1. RANDOMIZATION")
print("   Multi-stage sampling: random building → 4 random teachers →")
print("   systematic sampling every 9th student. Condition: MET.\n")
print("2. INDEPENDENCE (10% Condition)")
print(f"   Sample n = 66. Need population > {pop_needed}")
print("   Doral Academy enrollment far exceeds 660. Condition: MET.\n")
print("3. NEARLY NORMAL / LARGE SAMPLE")
print(f"   Music group:   n1 = {n1} (≥ 30) → CLT applies.")
print(f"   Silence group: n2 = {n2} (≥ 15, Likert scale bounded 1–5,")
print("   extreme outliers impossible). Condition: REASONABLY MET.\n")

# ============================================================
# 5. HYPOTHESIS TEST — Two-Sample t-Test  (Unit 8)
# ============================================================
print("── SECTION 4: TWO-SAMPLE t-TEST ──────────────────\n")

print("H₀: μ_music = μ_silence  (no difference in mean productivity)")
print("Hₐ: μ_music ≠ μ_silence  (difference exists)  α = 0.05\n")

# Compute using exact paper values
diff_means = mean1 - mean2
SE         = np.sqrt((sd1**2 / n1) + (sd2**2 / n2))
t_stat     = diff_means / SE

# Welch degrees of freedom
num_df   = ((sd1**2/n1) + (sd2**2/n2))**2
denom_df = ((sd1**2/n1)**2 / (n1-1)) + ((sd2**2/n2)**2 / (n2-1))
df_welch = num_df / denom_df

p_value  = 2 * stats.t.sf(abs(t_stat), df=df_welch)

print(f"Difference in means  : x̄1 - x̄2 = {mean1:.3f} - {mean2:.3f} = {diff_means:.3f}")
print(f"Standard Error (SE)  : √[(s1²/n1)+(s2²/n2)] = {SE:.4f}")
print(f"Test Statistic (t)   : {diff_means:.3f} / {SE:.4f} = {t_stat:.2f}")
print(f"Degrees of Freedom   : {df_welch:.2f} (Welch's approximation)")
print(f"p-value (two-sided)  : {p_value:.6f}\n")

print(f"DECISION: p-value = {p_value:.6f} < α = 0.05")
print("CONCLUSION: We REJECT H₀. There is strong statistical evidence")
print("that mean perceived productivity differs between students who")
print("study with music and those who study in silence at Doral Academy.\n")

# Verify with scipy's built-in Welch t-test (on simulated data)
print("── scipy ttest_ind() VERIFICATION ──────────────")
t_result = stats.ttest_ind(music_scores, silence_scores,
                            equal_var=False, alternative="two-sided")
print(f"  t = {t_result.statistic:.4f}")
print(f"  p = {t_result.pvalue:.6f}")
print(f"  df = {t_result.df:.2f}\n")

# ============================================================
# 6. CONFIDENCE INTERVAL  (Unit 6)
# ============================================================
print("── SECTION 5: 95% CONFIDENCE INTERVAL ────────────\n")

alpha    = 0.05
t_crit   = stats.t.ppf(1 - alpha/2, df=df_welch)
ME       = t_crit * SE
CI_lower = diff_means - ME
CI_upper = diff_means + ME

print(f"Critical value t*    : {t_crit:.3f}  (df ≈ {df_welch:.1f}, 95% CI)")
print(f"Margin of Error (ME) : t* × SE = {t_crit:.3f} × {SE:.4f} = {ME:.3f}")
print(f"95% Confidence Interval: ({CI_lower:.3f},  {CI_upper:.3f})\n")

print(f"INTERPRETATION: We are 95% confident that the true difference")
print(f"in mean productivity (music − silence) is between "
      f"{CI_lower:.3f} and {CI_upper:.3f} points.")
print("Because the interval does NOT contain 0, this confirms a")
print("statistically significant difference at α = 0.05.\n")

# ============================================================
# 7. PRACTICAL SIGNIFICANCE  (Effect Size — Cohen's d)
# ============================================================
print("── SECTION 6: EFFECT SIZE (Practical Significance) ─\n")

sp       = np.sqrt(((n1-1)*sd1**2 + (n2-1)*sd2**2) / (n1 + n2 - 2))
cohens_d = diff_means / sp

print(f"Pooled SD (sp)       : {sp:.4f}")
print(f"Cohen's d            : {diff_means:.4f} / {sp:.4f} = {cohens_d:.2f}")
print("Interpretation:")
print("  d < 0.2  → small effect")
print("  d < 0.5  → medium effect")
print("  d ≥ 0.8  → large effect")
print(f"  d = {cohens_d:.2f} → LARGE practical effect size.\n")

# ============================================================
# 8. SAMPLING DISTRIBUTION VISUALIZATION  (Unit 5)
# ============================================================
print("── SECTION 7: SAMPLING DISTRIBUTION PLOT ─────────\n")

x_range = np.linspace(t_stat - 5, t_stat + 5, 500)
density  = stats.t.pdf(x_range, df=round(df_welch))

fig, ax = plt.subplots(figsize=(8, 5))
ax.plot(x_range, density, color="black", linewidth=1)

# Shade rejection regions
ax.fill_between(x_range, density,
                where=(x_range >= abs(t_stat)),
                color="#E63946", alpha=0.5)
ax.fill_between(x_range, density,
                where=(x_range <= -abs(t_stat)),
                color="#E63946", alpha=0.5)

ax.axvline( t_stat, linestyle="--", color="#E63946")
ax.axvline(-t_stat, linestyle="--", color="#E63946")

ax.annotate(f"t = {t_stat:.2f}",
            xy=(t_stat, 0.02), xytext=(t_stat + 0.3, 0.03), fontsize=10)
ax.text(0, density.max() * 0.85,
        f"p-value ≈ {p_value:.5f}",
        ha="center", color="#E63946", fontsize=11, fontweight="bold")

ax.set_xlabel("t statistic")
ax.set_ylabel("Density")
ax.set_title("Sampling Distribution Under H₀ (Two-Sample t-Test)",
             fontweight="bold")
ax.set_title(f"df ≈ {df_welch:.1f} | Shaded areas = p-value", loc="right",
             fontsize=9, color="gray")
ax.set_title("Sampling Distribution Under H₀ (Two-Sample t-Test)",
             fontweight="bold", loc="left")
plt.tight_layout()
plt.savefig("sampling_distribution.png", dpi=150)
plt.close()
print("Saved: sampling_distribution.png\n")

