import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
from scipy import stats

# ============================================================
# 1. DATA ENTRY
#    Raw group summary statistics from the survey
# ============================================================

# Music group
n1    = 48
mean1 = 4.125
sd1   = 0.789

# Silence group
n2    = 18
mean2 = 2.611
sd2   = 1.378

# Re-create approximate raw data from group stats
rng = np.random.default_rng(42)
music_scores   = rng.normal(loc=mean1, scale=sd1,   size=n1)
silence_scores = rng.normal(loc=mean2, scale=sd2,   size=n2)

# Round and clamp to valid Likert range [1, 5]
music_scores   = np.clip(np.round(music_scores).astype(int),   1, 5)
silence_scores = np.clip(np.round(silence_scores).astype(int), 1, 5)

# Combine into one DataFrame
data = pd.DataFrame({
    "score":       np.concatenate([music_scores, silence_scores]),
    "environment": (["Music"] * n1) + (["Silence"] * n2)
})

print("===================================================")
print(" AP STATISTICS PROJECT — FULL PYTHON ANALYSIS OUTPUT")
print("===================================================\n")

# ============================================================
# 2. DESCRIPTIVE STATISTICS  (Unit 1)
# ============================================================
print("── SECTION 1: DESCRIPTIVE STATISTICS ─────────────\n")

def describe_group(scores, name):
    q1, q3 = np.percentile(scores, [25, 75])
    print(f"{name} Group:")
    print(f"  n      = {len(scores)}")
    print(f"  mean   = {np.mean(scores):.3f}")
    print(f"  sd     = {np.std(scores, ddof=1):.3f}")
    print(f"  median = {np.median(scores):.1f}")
    print(f"  min    = {np.min(scores)}")
    print(f"  Q1     = {q1:.2f}")
    print(f"  Q3     = {q3:.2f}")
    print(f"  max    = {np.max(scores)}\n")

describe_group(music_scores,   "Music")
describe_group(silence_scores, "Silence")

print("[Note: Inference uses original paper values — "
      "n1=48, x̄1=4.125, s1=0.789; n2=18, x̄2=2.611, s2=1.378]\n")

